# Google Service Account credentials
# See README.md for setup instructions

# Option 1 (recommended for Vercel): Base64-encode the entire JSON key file
# Run: base64 -i your-key-file.json (macOS/Linux) or use an online tool
GOOGLE_CREDENTIALS_BASE64=

# Option 2 (for local dev): Individual environment variables
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Required: your Google Calendar ID (Gmail address for primary calendar)
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
